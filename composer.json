{
    "name": "wanted/whatsapp-psr7-stream-crypto",
    "description": "PSR-7 stream decorators for WhatsApp-compatible media encryption/decryption",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bin/whatsapp-media"
    ],
    "require": {
        "ext-hash": "*",
        "ext-openssl": "*",
        "php": "^8.1",
        "psr/http-message": "^1.1 || ^2.0",
        "guzzlehttp/psr7": "^2.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Wanted\\WhatsappMedia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wanted\\WhatsappMedia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
